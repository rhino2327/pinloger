{
  "name": "pinloger",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build:android": "eas build --platform android --profile preview",
    "build:ios": "eas build --platform ios --profile preview",
    "build:prod": "eas build --platform all --profile production",
    "submit:ios": "eas submit --platform ios --latest",
    "deploy:web": "npx expo export -p web && npx firebase deploy --only hosting"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/material-top-tabs": "^7.4.27",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/stack": "^7.9.2",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.13.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-pager-view": "^6.9.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-tab-view": "^4.3.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "private": true,
  "devDependencies": {
    "@expo/ngrok": "^4.1.3"
  }
}
